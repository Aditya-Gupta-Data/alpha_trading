# Copy this file to .env and fill in your details.
# This file (.env.example) is safe to commit — .env itself is git-ignored
# so your password never gets uploaded.

# The Gmail address alerts will be sent FROM.
# Needs a 16-character "App Password", NOT your normal Gmail password.
# See README.md for how to create one.
ALERT_EMAIL_FROM=youraddress@gmail.com
ALERT_EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where alerts get sent TO. Leave blank to default to ALERT_EMAIL_FROM.
ALERT_EMAIL_TO=adigupta1998@gmail.com

# Phase 4D — news sentiment (optional).
# Free API key from Google AI Studio (https://aistudio.google.com/apikey).
# If left blank, news_processor.py still runs but writes neutral "stale"
# sentiment instead of a real read — nothing else breaks.
GEMINI_API_KEY=

# FastAPI gate when the backend is exposed via Cloudflare Tunnel.
# When set, every /api/* route (except GET /api/health) requires the same
# value in an x-api-key request header. Leave blank for localhost-only dev
# with `src.api:app` ONLY — the public gateway (`src.api_server:app`, the
# process the tunnel points at) is fail-closed and refuses ALL requests
# with 503 until this is set. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Where the Discord bot finds the Phase 9 gateway for /pending buttons
# (optional). Default http://127.0.0.1:8000 is correct when the bot runs
# on the same machine as the gateway (the VM). Only set this if the bot
# runs elsewhere — e.g. the public tunnel URL from `cloudflared`.
BRIDGE_BASE_URL=

# Discord push notifications (optional). Channel settings -> Integrations
# -> Webhooks -> New Webhook -> Copy URL. When set, the API's background
# loops push watchlist alerts and resolved-trade Episodes to that channel.
# Leave blank to disable (everything else keeps working).
DISCORD_WEBHOOK_URL=

# Phase 10B — local LLM parser (optional). Needs Ollama installed and a
# model pulled (`ollama pull llama3`). Both values below are the defaults;
# leave blank unless yours differ. Used ONLY for text-to-JSON parsing into
# the Brain Map — never for market monitoring (DECISIONS.md #30).
OLLAMA_BASE_URL=
OLLAMA_MODEL=
